<Window
    x:Class="UI.UniTest.UniTestflow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UI.UniTest"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="UI 系統架構測試平台"
    Width="1200"
    Height="900"
    MinWidth="800"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    Background="#F5F5F5"
    mc:Ignorable="d">

    <!-- 視窗資源定義 -->
    <Window.Resources>
        <!-- 按鈕樣式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E6DA4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 特殊功能按鈕樣式 -->
        <Style x:Key="SpecialButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#5CB85C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#449D44"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#398439"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 警告功能按鈕樣式 -->
        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#F0AD4E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EC971F"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D58512"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 危險功能按鈕樣式 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#D9534F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C9302C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#AC2925"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 滾動條樣式 -->
        <Style x:Key="ModernScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{DynamicResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#BCBCBC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主要內容區域 -->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- 左側控制面板 -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="8" 
                BorderThickness="1" 
                BorderBrush="#E0E0E0">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 標題區域 -->
                <Border Grid.Row="0" 
                        Background="#2C3E50" 
                        CornerRadius="8,8,0,0" 
                        Padding="15,12">
                    <TextBlock Text="📋 測試功能選單" 
                               Foreground="White" 
                               FontSize="16" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- 滾動區域 -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,15,10,15"
                              Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                    <StackPanel Orientation="Vertical">

                        <!-- 配針流程測試區 -->
                        <TextBlock Text="🔧 配針流程測試" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#34495E"/>

                        <Button x:Name="NeedleAllcationTest"
                                Click="NeedleAllcationTestRun"
                                Content="配針流程圓帶測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <Button x:Name="btnNeedleDisplay"
                                Click="btnNeedleDisplay_Click"
                                Content="配針資料"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <Button x:Name="NeedleRunTest"
                                Click="NeedleRunTestRun"
                                Content="配針流程測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <!-- 分隔線 -->
                        <Separator Margin="0,15,0,15" Background="#E0E0E0"/>

                        <!-- 拔針流程測試區 -->
                        <TextBlock Text="🔄 拔針流程測試" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#34495E"/>

                        <Button x:Name="RemoveNeedleAllcationTest"
                                Click="RemoveNeedleAllcationTestRun"
                                Content="拔針流程圓帶測試"
                                Style="{StaticResource SpecialButtonStyle}"/>

                        <Button x:Name="RemoveNeedleRunTest"
                                Click="RemoveNeedleRunTestRun"
                                Content="拔針流程測試"
                                Style="{StaticResource SpecialButtonStyle}"/>

                        <Button x:Name="RemoveNeedleConfirm"
                                Click="InfoClick"
                                Content="拔針資料確認"
                                Style="{StaticResource SpecialButtonStyle}"/>

                        <!-- 分隔線 -->
                        <Separator Margin="0,15,0,15" Background="#E0E0E0"/>

                        <!-- Xplanner 系統測試區 -->
                        <TextBlock Text="⚙️ Xplanner 系統測試" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#34495E"/>

                        <Button Click="XplannerLoaderTest_Click"
                                Content="XplannerFlowTest"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <Button x:Name="XplannerLoaderTest"
                                Click="XplannerLoaderTest_Click"
                                Content="XplannerLoader 拔針演算法測試"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <!-- 分隔線 -->
                        <Separator Margin="0,15,0,15" Background="#E0E0E0"/>

                        <!-- 倉儲系統測試區 -->
                        <TextBlock Text="📦 倉儲系統測試" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#34495E"/>

                        <Button Click="IntoWarehouseTesting"
                                Content="倉儲入盒流程測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <Button Click="OutWarehouseTesting"
                                Content="倉儲領盒流程測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <Button Click="WarehouseDisplayedTesting"
                                Content="倉儲顯示測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <!-- 分隔線 -->
                        <Separator Margin="0,15,0,15" Background="#E0E0E0"/>

                        <!-- 工具測試區 -->
                        <TextBlock Text="🛠️ 工具測試" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#34495E"/>

                        <Button Click="ConvertPositionTesting"
                                Content="鑽針位置轉換測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <Button Click="OutputConverySensorTesting"
                                Content="取料感測器測試"
                                Style="{StaticResource ModernButtonStyle}"/>

                        <!-- 分隔線 -->
                        <Separator Margin="0,15,0,15" Background="#E0E0E0"/>

                        <!-- 系統維護區 -->
                        <TextBlock Text="⚠️ 系統維護" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Margin="5,0,5,10" 
                                   Foreground="#E74C3C"/>

                        <Button Click="data_for_database"
                                Content="資料庫測試"
                                Style="{StaticResource DangerButtonStyle}"/>

                        <Button Content="自動模式警報處理"
                                Style="{StaticResource DangerButtonStyle}"/>

                        <Button Click="Batch_Click"
                                Content="批次處理"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <Button Click="UpdateStorage_Click"
                                Content="更新儲存"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <Button Click="RemovalTesting_Click"
                                Content="移除測試"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <Button Click="ReserveRecorded_Click"
                                Content="移除流程"
                                Style="{StaticResource WarningButtonStyle}"/>

                        <Button Click="CasualTestRun"
                                Content="暫存測試"
                                Style="{StaticResource WarningButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 分隔線 -->
        <GridSplitter Grid.Column="1" 
                      Background="#E0E0E0" 
                      HorizontalAlignment="Stretch"/>

        <!-- 右側顯示區域 -->
        <Border Grid.Column="2" 
                Background="White" 
                CornerRadius="8" 
                BorderThickness="1" 
                BorderBrush="#E0E0E0">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顯示區標題 -->
                <Border Grid.Row="0" 
                        Background="#34495E" 
                        CornerRadius="8,8,0,0" 
                        Padding="15,12">
                    <Grid>
                        <TextBlock Text="📊 測試結果顯示" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>

                        <!-- 過濾控制區 -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Center">
                            <Button Content="🔍 篩選" 
                                    Click="Filter"
                                    Background="Transparent"
                                    Foreground="White"
                                    BorderThickness="1"
                                    BorderBrush="White"
                                    Padding="8,4"
                                    Margin="0,0,10,0"
                                    FontSize="12"/>
                            <ComboBox x:Name="comboBoxFilter"
                                      Width="200"
                                      Background="White"
                                      BorderBrush="#BDC3C7"
                                      Padding="5">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Checked="CheckBox_Checked"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Unchecked="CheckBox_Unchecked"
                                                  Margin="2">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="12"/>
                                        </CheckBox>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 主要顯示區域 -->
                <Border Grid.Row="1" 
                        Background="#FAFAFA" 
                        Padding="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="display"
                                 Text="🚀 系統就緒，請選擇測試功能..."
                                 FontSize="14"
                                 FontFamily="Consolas, Microsoft YaHei"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 Foreground="#2C3E50"
                                 Padding="10"/>
                    </ScrollViewer>
                </Border>

                <!-- 狀態列 -->
                <Border Grid.Row="2" 
                        Background="#ECF0F1" 
                        CornerRadius="0,0,8,8" 
                        Padding="15,8">
                    <Grid>
                        <TextBlock Text="📍 狀態：待命中" 
                                   FontSize="12" 
                                   Foreground="#7F8C8D"
                                   HorizontalAlignment="Left"/>
                        <TextBlock FontSize="12" 
                                   Foreground="#7F8C8D"
                                   HorizontalAlignment="Right">
                            <Run Text="⏰ "/>
                            <Run Text="2025/07/20 系統啟動時間"/>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>