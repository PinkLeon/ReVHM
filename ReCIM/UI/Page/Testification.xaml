<Window
    x:Class="VHM.Testification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:HalconDotNet="clr-namespace:HalconDotNet;assembly=halcondotnet"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:VHM"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1920"
    Height="1080"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="0.8*" />
            <ColumnDefinition Width="0.3*" />
        </Grid.ColumnDefinitions>

        <!--  Column 0  -->
        <Border x:Name="HalconHost1" Grid.Column="0" />

        <!--  Column 1  -->
        <Border Grid.Column="1">
            <Grid>
                <DataGrid
                    x:Name="MainGrid"
                    Margin="10"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutoGenerateColumns="False"
                    Background="#393E41">

                    <!--  ⭐ Header 樣式（關鍵）  -->
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Background" Value="#393E41" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <!--  Item  -->
                        <DataGridTextColumn Binding="{Binding ItemName}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Item"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="#393E41" />
                                    <Setter Property="TextBlock.Foreground" Value="White" />
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>

                        </DataGridTextColumn>

                        <!--  TestNumber  -->
                        <DataGridTextColumn Binding="{Binding No}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="TestNumber"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <!--  Value  -->
                        <DataGridTextColumn Binding="{Binding MeasuredValue}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="MeasuredValue"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <!--  ToleranceType  -->
                        <DataGridTextColumn Binding="{Binding ToleranceType}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="ToleranceType"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <!--  Standard Value  -->
                        <DataGridTextColumn Binding="{Binding Spec}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Standard Value"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>



                        <!--  Tolerance  -->
                        <DataGridTextColumn Binding="{Binding Tolerance}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Tolerance"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <!--  Judgement  -->
                        <DataGridTextColumn Binding="{Binding Judgement}">
                            <DataGridTextColumn.Header>
                                <Label
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Judgement"
                                    FontFamily="Times New Roman"
                                    FontSize="16"
                                    Foreground="White" />
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="#393E41" />
                                    <Setter Property="TextBlock.Foreground" Value="White" />
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="18" />
                                    <Setter Property="Background" Value="#505457" />
                                </Style>
                            </DataGridTextColumn.CellStyle>

                        </DataGridTextColumn>
                        <!--  Rework  -->
                        <!--<DataGridTextColumn Binding="{Binding ReworkCheck}">
                            <DataGridTextColumn.Header>
                                <Label Content="Rework"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       FontFamily="Times New Roman"
                                       FontSize="16"
                                       Foreground="White"/>
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background"
                                            Value="{Binding NG, Converter={StaticResource MyConverter}}"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>-->

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!--  Column 2  -->
        <Border x:Name="HalconHost2" Grid.Column="2" />

        <!--  Column 3  -->
        <Border Grid.Column="3" Background="AliceBlue">
            <StackPanel Orientation="Vertical">
                <StackPanel>
                    <Button Click="GoButton_Click">
                        <materialDesign:PackIcon
                            Width="60"
                            Height="60"
                            HorizontalAlignment="Right"
                            Foreground="#EE565B"
                            Kind="LanguageGo" />
                    </Button>
                </StackPanel>
                <StackPanel Margin="0,30">
                    <Button Click="StopButton_Click">
                        <materialDesign:PackIcon
                            Width="60"
                            Height="60"
                            HorizontalAlignment="Right"
                            Foreground="#EE565B"
                            Kind="Stop" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
